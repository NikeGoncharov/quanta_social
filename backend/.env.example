# Copy to backend/.env and fill in for local dev or production.
# In production (ENVIRONMENT=production) the app REFUSES TO BOOT unless SECRET_KEY and
# ALLOWED_REGISTRATION_EMAILS are set (see app/config.py) — these are hard guards, not warnings.

# development | production
ENVIRONMENT=development

# SQLite (default resolves to backend/data/data.db). Override for a custom path.
# DATABASE_URL=sqlite+aiosqlite:///./data/data.db
# DATABASE_URL_SYNC=sqlite:///./data/data.db

# CORS origin of the SPA in local dev (prod is same-origin behind Caddy, so this is unused there).
FRONTEND_URL=http://localhost:5173

# --- Auth ---
# REQUIRED in production. Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=dev-insecure-change-me
ACCESS_TOKEN_TTL_MIN=30
REFRESH_TOKEN_TTL_DAYS=30
# Send auth cookies with the Secure flag (HTTPS only). Defaults to true in production, false in
# dev; leave unset to take that default. Set false only if serving prod over plain HTTP.
# COOKIE_SECURE=true

# Comma-separated allowlist of emails permitted to register. REQUIRED in production (invite-only);
# empty is allowed only in development.
ALLOWED_REGISTRATION_EMAILS=

# --- Guest demo mode ---
# One-click sandbox identity for the public case study. Guests auto-expire (a background reaper
# deletes each guest and everything they authored past the TTL).
GUEST_DEMO_ENABLED=true
GUEST_TTL_SECONDS=10800          # 3h — how long a guest session lives before it's reaped
GUEST_REAP_INTERVAL_SECONDS=1800 # 30m — how often the reaper sweeps
# Abuse guards for the public /demo/guest endpoint (generous for real visitors; tune if needed).
GUEST_RATE_LIMIT=20              # max guest mints per client IP ...
GUEST_RATE_WINDOW_SECONDS=60     # ... per this many seconds
GUEST_MAX_CONCURRENT=500         # hard ceiling on how many guests may exist at once

# --- Deploy ---
# Only if this project runs its OWN cloudflared (compose.yaml ships it commented out). The
# standard setup routes quanta-social.com through the shared homeserver tunnel → Caddy, and
# needs no token here.
# TUNNEL_TOKEN=
